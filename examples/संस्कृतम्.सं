# संस्कृतम् — the built-in Sanskrit linguistics library
# No other programming language in the world has this.

आनय "संस्कृतम्" इति सं।

# अक्षरविभागः — syllable splitting
वद(सं.अक्षराणि("नमस्ते"))।
वद("'संस्कृता' अक्षरगणना:", सं.अक्षरगणना("संस्कृता"))।

# transliteration — देवनागरी ↔ IAST
वद(सं.रोमनय("संस्कृता श्रेष्ठा भाषा"))।
वद(सं.देवनागरय("yoga dharma karma mokṣa"))।

# सन्धिः — the engine joins words by Pāṇini's vowel rules
वद(सं.संधय("देव", "आलयः"))।        # देवालयः (सवर्णदीर्घः)
वद(सं.संधय("महा", "ईशः"))।         # महेशः (गुणः)
वद(सं.संधय("गुरु", "उपदेशः"))।      # गुरूपदेशः
वद(सं.संधय("इति", "एवम्"))।        # इत्येवम् (यण्)
वद(सं.संधय("विद्या", "अर्थी"))।      # विद्यार्थी
वद(सं.संधय("ते", "अपि"))।          # तेऽपि (अवग्रहः)

# छन्दः — meter detection: the Gītā's first śloka!
मानय श्लोकः = "धर्मक्षेत्रे कुरुक्षेत्रे समवेता युयुत्सवः मामकाः पाण्डवाश्चैव किमकुर्वत सञ्जय"।
वद("मात्राः:", सं.मात्राः("धर्मक्षेत्रे"))।
वद("छन्दः:", सं.छन्दः(श्लोकः))।
