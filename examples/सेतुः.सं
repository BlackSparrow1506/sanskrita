# कोष्ठकाः — libraries, two ways:
# १. संस्कृत-कोष्ठकाः — our standard library, PURE Sanskrit names
# २. python-सेतुः — raw bridge to all ५ लक्षं python libraries

# —— १. शुद्धसंस्कृतम् ——
आनय "गणितम्" इति ग।
वद("वर्गमूलम्(१४४) =", ग.वर्गमूलम्(१४४))।
वद("घातः(२, १०) =", ग.घातः(२, १०))।
वद("ज्या(०) =", ग.ज्या(०))।            # Āryabhaṭa's ज्या!
वद("पाई =", ग.पाई)।

आनय "यादृच्छिकम्" इति यदृ।
वद("पाशकः (dice):", यदृ.अन्तरे(१, ६))।
वद("वरणम्:", यदृ.वरय(["आम्रम्", "कदली", "द्राक्षा"]))।

आनय "कालः" इति कालः।
वद("अद्य:", कालः.अद्य())।
वद("संप्रति:", कालः.संप्रति())।

# —— २. python-सेतुः (raw names, when no Sanskrit wrapper exists yet) ——
आनय "python:math" इति math।
वद("raw bridge:", math.sqrt(२५))।
