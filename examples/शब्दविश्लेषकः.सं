# शब्दविश्लेषकः — text analyzer (real-world: writing & research)
# Shows: वाक्यकर्म + संस्कृतम् libraries working together

आनय "वाक्यकर्म" इति वाक्।
आनय "संस्कृतम्" इति सं।

मानय पाठः = "विद्या ददाति विनयं विनयाद् याति पात्रताम् पात्रत्वाद् धनमाप्नोति धनाद् धर्मं ततः सुखम्"।

# शब्द विभाजन और गिनती
मानय शब्दाः = वाक्.विभज(पाठः, " ")।
वद("शब्दसङ्ख्या:", दैर्घ्यम्(शब्दाः))।
वद("अक्षरसङ्ख्या:", सं.अक्षरगणना(पाठः))।

# सबसे लंबा शब्द
मानय दीर्घतमः = ""।
प्रत्येकम् शब्दः इति शब्दाः {
    यदि (सं.अक्षरगणना(शब्दः) > सं.अक्षरगणना(दीर्घतमः)) {
        दीर्घतमः = शब्दः।
    }
}
वद("दीर्घतमः शब्दः:", दीर्घतमः, "(", सं.अक्षरगणना(दीर्घतमः), "अक्षराणि )")।

# transliteration for a global audience
वद("IAST:", सं.रोमनय(वाक्.अंश(पाठः, १, २५)))।

# frequency of a word
मानय स्थानम् = वाक्.खोज(पाठः, "धर्म")।
यदि (स्थानम् > ०) {
    वद("'धर्म' प्राप्तः स्थाने:", स्थानम्)।
} अन्यथा {
    वद("'धर्म' न प्राप्तः")।
}
