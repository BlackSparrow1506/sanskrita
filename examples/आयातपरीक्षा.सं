# आयातपरीक्षा — Phase 3 features: own-file imports, परिधिः, वाक्यकर्म, dict-अपनय

# १. अपनी .सं file import कीजिए — संस्कृता की अपनी libraries!
आनय "गणितसहायः.सं" इति सहायः।
वद(सहायः.अभिवादनम्)।
वद("द्विगुणः(२१) =", सहायः.द्विगुणः(२१))।
वद("वर्गफलम्(९) =", सहायः.वर्गफलम्(९))।

# २. परिधिः — counting loop, अब आसान!
मानय योगः = ०।
प्रत्येकम् इ इति परिधिः(१, १००) {
    योगः = योगः + इ।
}
वद("१..१०० योगः =", योगः)।

# ३. वाक्यकर्म — native string operations
आनय "वाक्यकर्म" इति वाक्यः।
मानय पङ्क्तिः = "राम-सीता-लक्ष्मण"।
मानय नामानि = वाक्यः.विभज(पङ्क्तिः, "-")।
वद("विभक्तम्:", नामानि)।
वद("संयोजितम्:", वाक्यः.संयोजय(नामानि, " • "))।
वद("खोज(सीता):", वाक्यः.खोज(पङ्क्तिः, "सीता"))।
वद("अंश(१,३):", वाक्यः.अंश("संस्कृता", १, ३))।

# ४. कोश से हटाइए — dict-अपनय
मानय छात्रः = {"नाम": "गौरी", "नगरम्": "पुणे", "वयः": २५}।
मानय निष्कासितम् = अपनय(छात्रः, "वयः")।
वद("निष्कासितम्:", निष्कासितम्, "• शेषः:", छात्रः)।
