# फिबोनाचि-श्रेणी — Fibonacci sequence
# (interesting fact: this sequence appears in Piṅgala's chandaḥśāstra,
#  centuries before Fibonacci — as मात्रामेरु / matrāmeru!)

मानय पूर्वः = ०।
मानय वर्तमानः = १।
मानय गणना = १।

वद("मात्रामेरुः (प्रथमाः १० सङ्ख्याः):")।
यावत् (गणना <= १०) {
    वद(पूर्वः)।
    मानय अग्रिमः = पूर्वः + वर्तमानः।
    पूर्वः = वर्तमानः।
    वर्तमानः = अग्रिमः।
    गणना = गणना + १।
}
