# ऋणगणकः — loan EMI calculator (real-world: home/car loan planning)
# EMI = P × r × (1+r)^n / ((1+r)^n − 1)

आनय "गणितम्" इति ग।

विधि मासिककिस्तिः(मूलधनम्, वार्षिकदरः, वर्षाणि) {
    मानय मासिकदरः = वार्षिकदरः / १२ / १००।
    मानय मासाः = वर्षाणि * १२।
    मानय गुणकः = ग.घातः(१ + मासिकदरः, मासाः)।
    फलम् मूलधनम् * मासिकदरः * गुणकः / (गुणकः - १)।
}

ध्रुव मूलधनम् = २०००००।       # ₹ 2 lakh loan
ध्रुव दरः = ८.५।              # 8.5% per year
ध्रुव वर्षाणि = ५।

मानय किस्तिः = मासिककिस्तिः(मूलधनम्, दरः, वर्षाणि)।
मानय समग्रभुक्तानम् = किस्तिः * वर्षाणि * १२।

वद("=== ऋणगणकः ===")।
वद("मूलधनम्      : ₹", मूलधनम्)।
वद("वार्षिकदरः   :", दरः, "%")।
वद("अवधिः        :", वर्षाणि, "वर्षाणि")।
वद("मासिककिस्तिः : ₹", ग.उपरितलम्(किस्तिः))।
वद("समग्रभुक्तानम्: ₹", ग.उपरितलम्(समग्रभुक्तानम्))।
वद("समग्रव्याजः  : ₹", ग.उपरितलम्(समग्रभुक्तानम् - मूलधनम्))।
