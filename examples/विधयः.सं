# विधयः — functions: first-class, recursive, with kāraka roles

विधि योग(क, ख) {
    फलम् क + ख।
}
वद("योगः:", योग(३, ४))।

# पुनरावृत्तिः (recursion)
विधि क्रमगुणितम्(म) {
    यदि (म <= १) { फलम् १। }
    फलम् म * क्रमगुणितम्(म - १)।
}
वद("७! =", क्रमगुणितम्(७))।

# kāraka-labeled arguments — the call reads like a Sanskrit sentence,
# and the roles may come in ANY order (like real Sanskrit!)
विधि प्रेषय(कर्म सन्देशः, सम्प्रदान प्राप्ता, करण मार्गः) {
    वद(सन्देशः, "→", प्राप्ता, "(", मार्गः, "द्वारा )")।
}
प्रेषय(कर्म: "नमस्ते", सम्प्रदान: "रामः", करण: "पत्रम्")।
प्रेषय(करण: "दूतः", सम्प्रदान: "सीता", कर्म: "स्वागतम्")।

# विधयः मूल्यानि सन्ति — functions are values! (no Strategy pattern needed)
विधि द्विगुणय(क) { फलम् क * २। }
विधि वर्गय(क) { फलम् क * क। }
विधि प्रयोजय(परिवर्तकः, मूल्यम्) { फलम् परिवर्तकः(मूल्यम्)। }
वद(प्रयोजय(द्विगुणय, १०), प्रयोजय(वर्गय, १०))।
