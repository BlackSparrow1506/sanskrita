# संवादः — interactive conversation (पृच्छ = ask)
# Terminal: it asks you live. Playground: type answers first
# in the प्रवेशः box (one per line), then press चालय ।

मानय नाम = पृच्छ("तव नाम किम्? ")।
वद("नमस्ते,", नाम, "!")।

मानय उत्तरम् = पृच्छ("तव वयः किम्? ")।
मानय वयः = सङ्ख्या(उत्तरम्)।

यदि (वयः >= १८) {
    वद("भवान् प्रौढः अस्ति ।")।
} अन्यथा {
    वद("भवान्", १८ - वयः, "वर्षानन्तरं प्रौढः भविष्यति ।")।
}
