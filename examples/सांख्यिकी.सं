# सांख्यिकी — statistics via the python bridge (data analysis in Sanskrit!)

आनय "python:statistics" इति सांख्यिकी।

मानय अङ्काः = [९५, ८८, ९२, ७६, ८५, ९१]।
वद("अङ्काः:", अङ्काः)।
वद("माध्यम् (mean):", सांख्यिकी.mean(अङ्काः))।
वद("मध्यगः (median):", सांख्यिकी.median(अङ्काः))।
वद("विचलनम् (stdev):", सांख्यिकी.stdev(अङ्काः))।

# JSON — read data from the web's most common format
आनय "python:json" इति json।
मानय पाठः = "{\"नाम\": \"गौरी\", \"नगरम्\": \"पुणे\", \"वयः\": 25}"।
मानय दत्तांशः = json.loads(पाठः)।
वद("नाम:", दत्तांशः["नाम"], "• नगरम्:", दत्तांशः["नगरम्"])।
