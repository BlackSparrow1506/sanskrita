# कारकक्रमः — kāraka arguments: order doesn't matter!
# Run: sanskrita examples/कारकक्रमः.सं

विधि प्रेषय(कर्म सन्देशः, सम्प्रदान प्राप्ता, करण मार्गः) {
    वद(सन्देशः, "→", प्राप्ता, "(", मार्गः, "द्वारा )")।
}

# एक ही call — तीन अलग-अलग orders में। जवाब हमेशा वही!
प्रेषय(कर्म: "नमस्ते", सम्प्रदान: "रामः", करण: "पत्रम्")।
प्रेषय(सम्प्रदान: "रामः", करण: "पत्रम्", कर्म: "नमस्ते")।
प्रेषय(करण: "पत्रम्", कर्म: "नमस्ते", सम्प्रदान: "रामः")।

# और engine ग़लत कारक पकड़ भी लेता है — try uncommenting:
# प्रेषय(कर्ता: "नमस्ते")।     # ← दोषः: 'प्रेषय' विधौ अज्ञातं कारकम् 'कर्ता'
वद("---")।
वद("तीनों बार एक ही जवाब — यही पाणिनि की शक्ति!")।
