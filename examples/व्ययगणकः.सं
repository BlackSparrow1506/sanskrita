# व्ययगणकः — monthly expense tracker (real-world: घर का बजट)
# Shows: lists of maps, functions, exact decimals, category totals

मानय व्ययाः = [
    {"नाम": "शाकम्",     "वर्गनाम": "भोजनम्",  "मूल्यम्": ४५०.५०},
    {"नाम": "दुग्धम्",    "वर्गनाम": "भोजनम्",  "मूल्यम्": ३२०.२५},
    {"नाम": "पुस्तकम्",   "वर्गनाम": "शिक्षा",   "मूल्यम्": ५९९.००},
    {"नाम": "यानभाटकम्", "वर्गनाम": "यात्रा",   "मूल्यम्": १२००.००},
    {"नाम": "लेखनी",     "वर्गनाम": "शिक्षा",   "मूल्यम्": ४५.७५}
]।

विधि समग्रम्(सूचिका) {
    मानय योगः = ०।
    प्रत्येकम् व्ययः इति सूचिका {
        योगः = योगः + व्ययः["मूल्यम्"]।
    }
    फलम् योगः।
}

विधि वर्गानुसारम्(सूचिका) {
    मानय कोशकः = {}।
    प्रत्येकम् व्ययः इति सूचिका {
        मानय वर्गपदम् = व्ययः["वर्गनाम"]।
        प्रयत {
            कोशकः[वर्गपदम्] = कोशकः[वर्गपदम्] + व्ययः["मूल्यम्"]।
        } दोषे (त्रुटिः) {
            कोशकः[वर्गपदम्] = व्ययः["मूल्यम्"]।
        }
    }
    फलम् कोशकः।
}

वद("=== मासिकव्ययपत्रम् ===")।
प्रत्येकम् व्ययः इति व्ययाः {
    वद(" ", व्ययः["नाम"], "—", व्ययः["मूल्यम्"], "₹")।
}
वद("---")।
मानय वर्गयोगाः = वर्गानुसारम्(व्ययाः)।
प्रत्येकम् कुं इति कुञ्जिकाः(वर्गयोगाः) {
    वद(कुं, ":", वर्गयोगाः[कुं], "₹")।
}
वद("---")।
वद("समग्रव्ययः:", समग्रम्(व्ययाः), "₹")।     # exact decimals — पैसा कभी नहीं खोता!
