# वर्गाः — classes: सृज (create), आरम्भ (constructor), अयम् (this)

वर्गः विद्यार्थी {
    विधि आरम्भ(नाम, वयः) {
        अयम्.नाम = नाम।
        अयम्.वयः = वयः।
        अयम्.अङ्काः = []।
    }

    विधि अङ्कं_योजय(अङ्कः) {
        योजय(अयम्.अङ्काः, अङ्कः)।
    }

    विधि माध्यम्() {
        मानय योगः = ०।
        प्रत्येकम् अ इति अयम्.अङ्काः {
            योगः = योगः + अ।
        }
        फलम् योगः / दैर्घ्यम्(अयम्.अङ्काः)।
    }

    विधि परिचय() {
        वद("अहं", अयम्.नाम, "—", अयम्.वयः, "वर्षीयः, माध्यमाङ्कः", अयम्.माध्यम्())।
    }
}

मानय रमा = सृज विद्यार्थी("रमा", २०)।
रमा.अङ्कं_योजय(९५)।
रमा.अङ्कं_योजय(८८)।
रमा.अङ्कं_योजय(९२)।
रमा.परिचय()।

मानय अर्जुनः = सृज विद्यार्थी("अर्जुनः", २२)।
अर्जुनः.अङ्कं_योजय(७५)।
अर्जुनः.अङ्कं_योजय(८५)।
अर्जुनः.परिचय()।
