# १ तः ५ पर्यन्तं गणना (counting 1 to 5)
मानय क = १।
यावत् (क <= ५) {
    वद(क)।
    क = क + १।
}

# दशमांश-परीक्षा — ०.१ + ०.२ = ०.३ (शुद्धम्! Python/Java अत्र स्खलतः)
वद(०.१ + ०.२)।

# शर्तपरीक्षा (condition test)
यदि (क == ६) {
    वद("गणना समाप्ता")।
} अथ यदि (क > ६) {
    वद("अधिकम्")।
} अन्यथा {
    वद("न्यूनम्")।
}

# ध्रुवः (constant)
ध्रुव पाई = ३.१४१५९।
वद("पाई =", पाई)।

# तर्कः (logic)
मानय वयः = २०।
यदि (वयः >= १८ च वयः < ६०) {
    वद("प्रौढः")।
}
