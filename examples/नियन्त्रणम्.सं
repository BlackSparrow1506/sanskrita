# नियन्त्रणम् — loop control & types (विरम, अनुवर्त, प्रकाराः)

# विरम (break): stop at the first number divisible by ७ after ५०
मानय क = ५१।
यावत् (सत्यम्) {
    यदि (क % ७ == ०) {
        वद("प्राप्तम्:", क)।
        विरम।
    }
    क = क + १।
}

# अनुवर्त (continue): print only odd numbers
मानय इ = ०।
यावत् (इ < १०) {
    इ = इ + १।
    यदि (इ % २ == ०) {
        अनुवर्त।
    }
    वद("विषमः:", इ)।
}

# type annotations — the engine guards the declared type
मानय वयः : पूर्णाङ्कः = २५।
मानय नाम : वाक्यम् = "गौरी"।
वयः = वयः + १।                    # fine — still पूर्णाङ्कः
# वयः = "पञ्चविंशतिः"।            # ← uncomment to see the type error!

# प्रकारः and दैर्घ्यम्
वद(प्रकारः(वयः), प्रकारः(नाम), प्रकारः(३.१४), प्रकारः(सत्यम्))।
वद("नाम्नः दैर्घ्यम्:", दैर्घ्यम्(नाम))।
