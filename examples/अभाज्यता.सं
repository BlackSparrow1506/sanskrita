# अभाज्यता-परीक्षा — prime number check
# uses % (शेषः / remainder) and a boolean flag

मानय सङ्ख्या = ९७।
मानय अभाज्या = सत्यम्।
मानय भाजकः = २।

यदि (सङ्ख्या < २) {
    अभाज्या = असत्यम्।
}

यावत् (भाजकः * भाजकः <= सङ्ख्या) {
    यदि (सङ्ख्या % भाजकः == ०) {
        अभाज्या = असत्यम्।
    }
    भाजकः = भाजकः + १।
}

यदि (अभाज्या) {
    वद(सङ्ख्या, "अभाज्या अस्ति (prime)")।
} अन्यथा {
    वद(सङ्ख्या, "भाज्या अस्ति (not prime)")।
}
