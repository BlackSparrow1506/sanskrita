# दोषनिवारणम् — error handling: प्रयत (try) / दोषे (catch)

प्रयत {
    मानय क = १० / ०।
    वद("एतत् कदापि न दृश्यते")।
} दोषे (त्रुटिः) {
    वद("दोषः गृहीतः:", त्रुटिः)।
}
वद("कार्यक्रमः जीवति!")।

# व्यावहारिकम् — safe number reading
विधि सुरक्षित_सङ्ख्या(पाठः) {
    प्रयत {
        फलम् सङ्ख्या(पाठः)।
    } दोषे (त्रुटिः) {
        वद("(", पाठः, "सङ्ख्या न — शून्यं ददामि )")।
        फलम् ०।
    }
}
वद(सुरक्षित_सङ्ख्या("४२"))।
वद(सुरक्षित_सङ्ख्या("नमस्ते"))।
