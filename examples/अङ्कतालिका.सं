# अङ्कतालिका — class grade report (real-world: teachers!)
# Shows: classes, lists, functions, kāraka arguments together

वर्गः छात्रः {
    विधि आरम्भ(नाम, अङ्काः) {
        अयम्.नाम = नाम।
        अयम्.अङ्काः = अङ्काः।
    }
    विधि माध्यम्() {
        मानय योगः = ०।
        प्रत्येकम् अ इति अयम्.अङ्काः { योगः = योगः + अ। }
        फलम् योगः / दैर्घ्यम्(अयम्.अङ्काः)।
    }
    विधि श्रेणी() {
        मानय मा = अयम्.माध्यम्()।
        यदि (मा >= ९०) { फलम् "अ+"। }
        अथ यदि (मा >= ७५) { फलम् "अ"। }
        अथ यदि (मा >= ६०) { फलम् "ब"। }
        अन्यथा { फलम् "स"। }
    }
}

विधि पङ्क्तिं_मुद्रय(कर्ता विद्यार्थी) {
    वद(" ", विद्यार्थी.नाम, "—", विद्यार्थी.माध्यम्(), "—", विद्यार्थी.श्रेणी())।
}

मानय कक्षा = [
    सृज छात्रः("रमा",     [९५, ८८, ९२]),
    सृज छात्रः("अर्जुनः",  [७२, ८०, ६८]),
    सृज छात्रः("मीरा",    [६०, ५५, ६५])
]।

वद("=== कक्षा-अङ्कतालिका ===")।
वद("नाम — माध्यम् — श्रेणी")।
प्रत्येकम् वि इति कक्षा {
    पङ्क्तिं_मुद्रय(कर्ता: वि)।
}

# कक्षा का topper
मानय श्रेष्ठः = कक्षा[१]।
प्रत्येकम् वि इति कक्षा {
    यदि (वि.माध्यम्() > श्रेष्ठः.माध्यम्()) { श्रेष्ठः = वि। }
}
वद("---")।
वद("सर्वश्रेष्ठः:", श्रेष्ठः.नाम, "— अभिनन्दनम्!")।
