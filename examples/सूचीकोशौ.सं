# सूची (list) & कोशः (map)
# संस्कृता १ तः गणयति — प्रथमः = १ (1-based, as Sanskrit counts!)

मानय फलानि = ["आम्रम्", "कदली", "द्राक्षा"]।
वद("प्रथमं फलम्:", फलानि[१])।
वद("दैर्घ्यम्:", दैर्घ्यम्(फलानि))।

योजय(फलानि, "नारिकेलम्")।           # append
फलानि[२] = "कदलीफलम्"।              # replace
वद(फलानि)।

# (नोट: 'फलम्' चरनाम न भवति — तत् return-कीवर्ड्! we use वस्तु)
प्रत्येकम् वस्तु इति फलानि {
    वद("-", वस्तु)।
}

मानय अङ्काः = [५, २, ९, १]।
वद("क्रमितम्:", क्रमय(अङ्काः))।
वद("निष्कासितम्:", अपनय(अङ्काः, १))।    # remove 1st, returns it

# कोशः — key/value store
मानय छात्रः = {"नाम": "गौरी", "वयः": २५}।
छात्रः["नगरम्"] = "पुणे"।
वद(छात्रः["नाम"], "•", छात्रः["नगरम्"])।

प्रत्येकम् कुञ्जिका इति कुञ्जिकाः(छात्रः) {
    वद(कुञ्जिका, "=", छात्रः[कुञ्जिका])।
}
