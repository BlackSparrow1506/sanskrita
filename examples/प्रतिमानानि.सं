# अभिकल्पनप्रतिमानानि — design patterns in संस्कृता
# (see ../docs/अभिकल्पनप्रतिमानानि.md for the full guide)

# —— १. निर्माता (Factory) — one विधि decides which वर्गः to create ——
वर्गः वृत्तम् {
    विधि आरम्भ(त्रिज्या) { अयम्.त्रिज्या = त्रिज्या। }
    विधि क्षेत्रफलम्() { फलम् ३.१४१५९ * अयम्.त्रिज्या * अयम्.त्रिज्या। }
}
वर्गः चतुरस्रम् {
    विधि आरम्भ(भुजा) { अयम्.भुजा = भुजा। }
    विधि क्षेत्रफलम्() { फलम् अयम्.भुजा * अयम्.भुजा। }
}
विधि आकृतिनिर्माता(रूपम्, मापः) {
    यदि (रूपम् == "वृत्तम्") { फलम् सृज वृत्तम्(मापः)। }
    फलम् सृज चतुरस्रम्(मापः)।
}
मानय आकृतिः = आकृतिनिर्माता("वृत्तम्", ७)।
वद("वृत्तक्षेत्रफलम्:", आकृतिः.क्षेत्रफलम्())।

# —— २. दर्शकः (Observer) — listeners react to announcements ——
# श्रोतारः विधयः एव! (observers are just functions)
वर्गः घोषकः {
    विधि आरम्भ() { अयम्.श्रोतारः = []। }
    विधि श्रोतारं_योजय(श्रोता) { योजय(अयम्.श्रोतारः, श्रोता)। }
    विधि घोषय(वार्ता) {
        प्रत्येकम् श्रोता इति अयम्.श्रोतारः { श्रोता(वार्ता)। }
    }
}
विधि छात्रकर्णः(वार्ता) { वद("छात्रः श्रुतवान्:", वार्ता)। }
विधि शिक्षककर्णः(वार्ता) { वद("शिक्षकः श्रुतवान्:", वार्ता)। }

मानय विद्यालयघोषकः = सृज घोषकः()।
विद्यालयघोषकः.श्रोतारं_योजय(छात्रकर्णः)।
विद्यालयघोषकः.श्रोतारं_योजय(शिक्षककर्णः)।
विद्यालयघोषकः.घोषय("श्वः परीक्षा!")।

# —— ३. उपायः (Strategy) — pass the policy as a function ——
# In Java this needs interfaces + classes; here: one argument.
विधि सामान्यमूल्यम्(मूल्यम्) { फलम् मूल्यम्। }
विधि उत्सवमूल्यम्(मूल्यम्) { फलम् मूल्यम् * ८ / १०। }
विधि देयम्(मूल्यम्, नीतिः) { फलम् नीतिः(मूल्यम्)। }
वद("सामान्यम्:", देयम्(५००, सामान्यमूल्यम्))।
वद("उत्सवे:", देयम्(५००, उत्सवमूल्यम्))।

# —— ४. एकाकी (Singleton) — a ध्रुव at the top IS the singleton ——
# No special class needed: ध्रुव guarantees one unchangeable binding.
ध्रुव विन्यासः = {"भाषा": "संस्कृता", "संस्करणम्": "०.२"}।
वद("विन्यासः:", विन्यासः["भाषा"], विन्यासः["संस्करणम्"])।
