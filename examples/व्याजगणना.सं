# सरलव्याजगणना — simple interest calculator
# दशमांशाः शुद्धाः — exact decimal arithmetic!

ध्रुव मूलधनम् = १००००।       # principal ₹
ध्रुव दरः = ७.५।             # rate % per year
ध्रुव कालः = ३।              # years

मानय व्याजः = मूलधनम् * दरः * कालः / १००।
मानय समग्रम् = मूलधनम् + व्याजः।

वद("मूलधनम्  : ₹", मूलधनम्)।
वद("दरः      :", दरः, "%")।
वद("कालः     :", कालः, "वर्षाणि")।
वद("व्याजः    : ₹", व्याजः)।
वद("समग्रम्   : ₹", समग्रम्)।
